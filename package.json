{
  "name": "simufeu",
  "version": "1.0.0",
  "private": true,
  "main": "electron/main.js",
  "scripts": {
    "dev": "concurrently -k -n VITE,ELECTRON -c blue,green \"npm:dev:vite\" \"npm:dev:electron\"",
    "dev:vite": "vite",
    "dev:electron": "wait-on tcp:5173 && node scripts/dev-electron.js",
    "build:vite": "vite build",
    "build": "npm run build:vite && electron-builder",
    "build:win": "npm run build:vite && electron-builder --win --x64"
  },
  "build": {
    "appId": "com.simufeu.app",
    "productName": "SimuFeu",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": "nsis",
      "icon": "electron/assets/icon.ico"
    },
    "files": [
      "electron/**/*",
      "src/dist/**/*",
      "engine/**/*"
    ]
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.7.0",
    "concurrently": "^9.2.1",
    "electron": "^35.0.0",
    "electron-builder": "^25.0.0",
    "vite": "^6.4.3",
    "wait-on": "^9.0.10"
  },
  "dependencies": {
    "leaflet": "^1.9.4",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  }
}
